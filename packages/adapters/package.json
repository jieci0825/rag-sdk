{
    "name": "@rag-sdk/adapters",
    "version": "0.0.0",
    "type": "module",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./lang-chain": {
            "types": "./dist/lang-chain/index.d.mts",
            "default": "./dist/lang-chain/index.mjs"
        },
        "./langchain/loaders": {
            "types": "./dist/langchain/loaders/index.d.mts",
            "default": "./dist/langchain/loaders/index.mjs"
        },
        "./langchain/chunkers": {
            "types": "./dist/langchain/chunkers/index.d.mts",
            "default": "./dist/langchain/chunkers/index.mjs"
        },
        "./langchain/embeddings": {
            "types": "./dist/langchain/embeddings/index.d.mts",
            "default": "./dist/langchain/embeddings/index.mjs"
        }
    },
    "scripts": {
        "build": "tsdown",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@langchain/classic": "^1.0.34",
        "@langchain/community": "^1.1.28",
        "@langchain/core": "^1.1.48",
        "@rag-sdk/core": "workspace:*",
        "@rag-sdk/indexing": "workspace:*",
        "@rag-sdk/utils": "workspace:*",
        "pdf-parse": "^2.4.5"
    }
}
