{
    "name": "@rag-sdk/vector-stores",
    "version": "0.0.0",
    "type": "module",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./in-memory": {
            "types": "./dist/in-memory/index.d.mts",
            "default": "./dist/in-memory/index.mjs"
        },
        "./postgresql": {
            "types": "./dist/postgresql/index.d.mts",
            "default": "./dist/postgresql/index.mjs"
        }
    },
    "dependencies": {
        "@rag-sdk/indexing": "workspace:*",
        "@rag-sdk/utils": "workspace:*"
    }
}
